# BigShot dApp Environment Configuration Template
# Copy this file to .env and fill in the values

# ─── EVE Frontier World (Testnet) ────────────────────────────────────────────
# The package ID of the EVE World contract
VITE_EVE_WORLD_PACKAGE_ID=""

# The Sui GraphQL endpoint URL
VITE_SUI_GRAPHQL_ENDPOINT="https://graphql.testnet.sui.io/graphql"

# ─── BigShot Extension ───────────────────────────────────────────────────────
# The package ID of the BigShot extension contract
VITE_BIGSHOT_PACKAGE_ID=""

# The object ID of the shared ExtensionConfig
VITE_EXTENSION_CONFIG_ID=""

# The object ID of the LUX treasury
VITE_TREASURY_LUX_ID=""

# The object ID of the EVE token treasury
VITE_TREASURY_EVE_ID=""

# Killmail Registry ID for checking "Last Seen" tracking (Utopia network)
VITE_KILLMAIL_REGISTRY_ID=""
